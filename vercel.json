{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/vercel-status",
      "destination": "https://www.vercel-status.com/api/v2/status.json"
    },
    {
      "source": "/api/firebase-status",
      "destination": "https://status.firebase.google.com/incidents.json"
    },
    {
      "source": "/api/gcloud-status",
      "destination": "https://status.cloud.google.com/incidents.json"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
