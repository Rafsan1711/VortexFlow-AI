{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml",
      "headers": {
        "Content-Type": "application/xml; charset=utf-8",
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8"
      }
    },
    {
      "src": "/api/vercel-status",
      "dest": "https://www.vercel-status.com/api/v2/status.json"
    },
    {
      "src": "/api/firebase-status",
      "dest": "https://status.firebase.google.com/incidents.json"
    },
    {
      "src": "/api/gcloud-status",
      "dest": "https://status.cloud.google.com/incidents.json"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
